generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

// ─────────────────────────────────────────────
// USER
// Basic user. Phone is important — 
// Tcell users are identified by phone number.
// ─────────────────────────────────────────────
model User {
  id        String   @id @db.Uuid
  username  String   @unique
  email     String   @unique
  phone     String?  @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  wallet             Wallet?
  challengesCreated  Challenge[]            @relation("ChallengeCreator")
  participations     ChallengeParticipant[]
  goalsCreated       Goal[]                 @relation("GoalCreator")
  goalCollaborations GoalCollaborator[]
  messages           Message[]
  notifications      Notification[]

  @@index([email])
  @@index([username])
  @@index([phone])
}

// ─────────────────────────────────────────────
// WALLET
// One per user. All fake for now.
// balance     — what the user can freely spend
// lockedBalance — committed to active challenges,
//                cannot be spent elsewhere
// Together: balance + lockedBalance = total money
// ─────────────────────────────────────────────
model Wallet {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId        String   @unique @db.Uuid
  balance       Decimal  @default(2000.00) @db.Decimal(10, 2)
  lockedBalance Decimal  @default(0.00) @db.Decimal(10, 2)
  currency      String   @default("TJS")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([userId])
}

// ─────────────────────────────────────────────
// WALLET TRANSACTION
// Every money movement ever. Never delete rows.
// type         — what kind of movement happened
// amount       — how much moved
// balanceBefore/After — snapshot for audit trail
// referenceId  — the challenge or goal that
//                triggered this transaction
// referenceType — "CHALLENGE" or "GOAL"
// ─────────────────────────────────────────────
model WalletTransaction {
  id            String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  walletId      String          @db.Uuid
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  balanceBefore Decimal         @db.Decimal(10, 2)
  balanceAfter  Decimal         @db.Decimal(10, 2)
  description   String?
  referenceId   String?         @db.Uuid
  referenceType String? // "CHALLENGE" or "GOAL"
  createdAt     DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([referenceId])
  @@index([type])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// CHALLENGE (Group Bill)
// The shared bill object.
// totalAmount   — the full bill amount
// splitType     — EQUAL splits evenly between
//                 all participants, CUSTOM means
//                 each participant has their own
//                 shareAmount set manually
// destination   — where the money goes when paid
//                 (landlord phone, bill reference)
// deadline      — optional. if null, app sends
//                 reminders after inactivity
// status        — lifecycle of the bill
// ─────────────────────────────────────────────
model Challenge {
  id          String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdBy   String            @db.Uuid
  title       String
  description String?
  category    ChallengeCategory // RENT, ELECTRICITY, WATER, INTERNET, OTHER
  totalAmount Decimal           @db.Decimal(10, 2)
  splitType   SplitType         @default(EQUAL)
  destination String? // Who gets paid at the end
  deadline    DateTime? // Optional
  status      ChallengeStatus   @default(ACTIVE)
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @default(now()) @updatedAt

  creator       User                   @relation("ChallengeCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  participants  ChallengeParticipant[]
  messages      Message[]              @relation("ChallengeMessages")
  notifications Notification[]

  @@index([createdBy])
  @@index([status])
  @@index([category])
  @@index([deadline])
}

// ─────────────────────────────────────────────
// CHALLENGE PARTICIPANT
// One row per person per challenge.
// shareAmount  — their specific cut of the bill
// status       — their personal progress:
//   INVITED    → added, hasn't responded
//   COMMITTED  → joined, money soft locked
//   PAID       → payment fired successfully
//   DECLINED   → they said no
// isAdmin      — can edit/cancel the challenge
// ─────────────────────────────────────────────
model ChallengeParticipant {
  id          String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  challengeId String            @db.Uuid
  userId      String            @db.Uuid
  shareAmount Decimal           @db.Decimal(10, 2)
  status      ParticipantStatus @default(INVITED)
  isAdmin     Boolean           @default(false)
  lockedAt    DateTime? // When soft lock was applied
  paidAt      DateTime? // When payment fired
  joinedAt    DateTime          @default(now())
  updatedAt   DateTime          @default(now()) @updatedAt

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([challengeId])
  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────────
// GOAL (Savings)
// Different from a challenge — money goes IN
// not OUT. People save toward a target.
// targetAmount      — the finish line
// currentAmount     — how much saved so far
// contributionAmount — how much per cycle
// frequency         — how often contributions happen
// nextContributionDate — when next one is due
// visibility        — who can see/join this goal:
//   PRIVATE         → only creator
//   COLLABORATIVE   → invited people contribute
//   PUBLIC          → anyone can see, none contribute
// ─────────────────────────────────────────────
model Goal {
  id                   String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdBy            String         @db.Uuid
  title                String
  description          String?
  targetAmount         Decimal        @db.Decimal(10, 2)
  currentAmount        Decimal        @default(0.00) @db.Decimal(10, 2)
  contributionAmount   Decimal        @db.Decimal(10, 2)
  frequency            GoalFrequency // DAILY, WEEKLY, MONTHLY
  nextContributionDate DateTime?
  visibility           GoalVisibility @default(PRIVATE)
  status               GoalStatus     @default(ACTIVE)
  completedAt          DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @default(now()) @updatedAt

  creator       User               @relation("GoalCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  collaborators GoalCollaborator[]
  messages      Message[]          @relation("GoalMessages")
  notifications Notification[]

  @@index([createdBy])
  @@index([status])
  @@index([visibility])
}

// ─────────────────────────────────────────────
// GOAL COLLABORATOR
// People invited to contribute to a goal.
// Only exists for COLLABORATIVE goals.
// totalContributed — running sum of what
//                    this person has put in
// ─────────────────────────────────────────────
model GoalCollaborator {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  goalId           String   @db.Uuid
  userId           String   @db.Uuid
  totalContributed Decimal  @default(0.00) @db.Decimal(10, 2)
  joinedAt         DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([goalId, userId])
  @@index([goalId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// MESSAGE
// One table for both challenge and goal chats.
// challengeId OR goalId — one will always be
// null depending on where the message lives.
// senderId     — null means system generated
// type         — USER or SYSTEM
// System messages fire automatically on events:
//   "Bahir committed 200 TJS ✅"
//   "Goal is 50% complete 🎉"
//   "2 days left on deadline ⏰"
// ─────────────────────────────────────────────
model Message {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  challengeId String?     @db.Uuid
  goalId      String?     @db.Uuid
  senderId    String?     @db.Uuid // null = system message
  content     String
  type        MessageType @default(USER)
  createdAt   DateTime    @default(now())

  challenge Challenge? @relation("ChallengeMessages", fields: [challengeId], references: [id], onDelete: Cascade)
  goal      Goal?      @relation("GoalMessages", fields: [goalId], references: [id], onDelete: Cascade)
  sender    User?      @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([challengeId])
  @@index([goalId])
  @@index([senderId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// NOTIFICATION
// In-app only. No push for hackathon.
// Every important event creates one row here.
// read         — has the user seen it yet
// referenceId  — the challenge or goal it's about
// referenceType — "CHALLENGE" or "GOAL"
// ─────────────────────────────────────────────
model Notification {
  id          String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String           @db.Uuid
  challengeId String?          @db.Uuid
  goalId      String?          @db.Uuid
  type        NotificationType
  title       String
  body        String
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge? @relation(fields: [challengeId], references: [id])
  goal      Goal?      @relation(fields: [goalId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TransactionType {
  TOPUP // Money added to wallet manually
  LOCK // Soft locked on challenge commit
  UNLOCK // Released when challenge fails/cancelled
  PAYMENT // Fired when challenge completes
  CONTRIBUTION // Added to a goal pool
  REWARD // Bonus credited after completion
}

enum ChallengeCategory {
  RENT
  ELECTRICITY
  WATER
  INTERNET
  TRIP
  GIFT
  OTHER
}

enum SplitType {
  EQUAL // App divides totalAmount evenly
  CUSTOM // Each participant has manual shareAmount
}

enum ChallengeStatus {
  ACTIVE // Running, accepting commitments
  COMPLETED // Everyone paid
  FAILED // Deadline passed, not complete
  CANCELLED // Creator cancelled
}

enum ParticipantStatus {
  INVITED // Added but no response yet
  COMMITTED // Joined + money soft locked
  PAID // Payment fired
  DECLINED // They said no
}

enum GoalFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum GoalVisibility {
  PRIVATE // Only creator sees and contributes
  COLLABORATIVE // Invited people contribute together
  PUBLIC // Anyone can see, nobody else contributes
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MessageType {
  USER // Real person sent this
  SYSTEM // App generated this automatically
}

enum NotificationType {
  SOMEONE_COMMITTED // A participant locked their share
  SOMEONE_PAID // A participant completed payment
  YOU_ARE_LAST // Everyone else committed except you
  DEADLINE_APPROACHING // 48 or 24 hours left
  NO_ACTIVITY_REMINDER // Bill has no deadline, people inactive
  CHALLENGE_COMPLETE // Everyone paid, bill done
  CHALLENGE_FAILED // Deadline passed, someone didn't pay
  GOAL_CONTRIBUTION_DUE // Your scheduled contribution is today
  GOAL_MILESTONE // 25%, 50%, 75%, 100% reached
  NEW_INVITE // You were added to a challenge or goal
}
