generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

model User {
  id                String              @id @db.Uuid
  username          String              @unique
  email             String              @unique
  phone             String?             @unique
  name              String?
  avatarUrl         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @default(now()) @updatedAt
  Group             Group[]
  GroupContribution GroupContribution[]
  GroupMember       GroupMember[]
  messages          Message[]
  notifications     Notification[]
  wallet            Wallet?

  @@index([email])
  @@index([username])
  @@index([phone])
}

model Wallet {
  id            String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId        String              @unique @db.Uuid
  balance       Decimal             @default(2000.00) @db.Decimal(10, 2)
  lockedBalance Decimal             @default(0.00) @db.Decimal(10, 2)
  currency      String              @default("TJS")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @default(now()) @updatedAt
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id            String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  walletId      String          @db.Uuid
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  balanceBefore Decimal         @db.Decimal(10, 2)
  balanceAfter  Decimal         @db.Decimal(10, 2)
  description   String?
  createdAt     DateTime        @default(now())
  groupId       String?         @db.Uuid
  wallet        Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
  @@index([groupId])
}

model Message {
  id        String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  senderId  String?     @db.Uuid
  content   String
  type      MessageType @default(USER)
  createdAt DateTime    @default(now())
  groupId   String      @db.Uuid
  Group     Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User?       @relation(fields: [senderId], references: [id])

  @@index([senderId])
  @@index([createdAt])
  @@index([groupId])
}

model Notification {
  id        String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  groupId   String?          @db.Uuid
  Group     Group?           @relation(fields: [groupId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([groupId])
}

model Group {
  id                   String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdBy            String              @db.Uuid
  type                 GroupType
  title                String
  description          String?
  status               GroupStatus         @default(ACTIVE)
  targetAmount         Decimal             @db.Decimal(10, 2)
  currentAmount        Decimal             @default(0.00) @db.Decimal(10, 2)
  completedAt          DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @default(now())
  category             GroupCategory?
  splitType            SplitType?
  destination          String?
  deadline             DateTime?
  frequency            GoalFrequency?
  contributionAmount   Decimal?            @db.Decimal(10, 2)
  nextContributionDate DateTime?
  visibility           GoalVisibility      @default(PRIVATE)
  User                 User                @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  GroupContribution    GroupContribution[]
  GroupMember          GroupMember[]
  Message              Message[]
  Notification         Notification[]

  @@index([createdBy])
  @@index([deadline])
  @@index([status])
  @@index([type])
  @@index([visibility])
}

model GroupContribution {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  groupId     String      @db.Uuid
  userId      String      @db.Uuid
  memberId    String      @db.Uuid
  amount      Decimal     @db.Decimal(10, 2)
  createdAt   DateTime    @default(now())
  Group       Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  GroupMember GroupMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  User        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([groupId])
  @@index([memberId])
  @@index([userId])
}

model GroupMember {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  groupId           String              @db.Uuid
  userId            String              @db.Uuid
  isAdmin           Boolean             @default(false)
  joinedAt          DateTime            @default(now())
  updatedAt         DateTime            @default(now())
  shareAmount       Decimal?            @db.Decimal(10, 2)
  status            MemberStatus        @default(INVITED)
  lockedAt          DateTime?
  paidAt            DateTime?
  totalContributed  Decimal             @default(0.00) @db.Decimal(10, 2)
  GroupContribution GroupContribution[]
  Group             Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  User              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([status])
  @@index([userId])
}

enum TransactionType {
  TOPUP
  LOCK
  UNLOCK
  PAYMENT
  CONTRIBUTION
  REWARD
}

enum SplitType {
  EQUAL
  CUSTOM
}

enum GoalFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum GoalVisibility {
  PRIVATE
  COLLABORATIVE
  PUBLIC
}

enum MessageType {
  USER
  SYSTEM
}

enum NotificationType {
  SOMEONE_COMMITTED
  SOMEONE_PAID
  YOU_ARE_LAST
  DEADLINE_APPROACHING
  NO_ACTIVITY_REMINDER
  GROUP_COMPLETE
  GROUP_FAILED
  GOAL_CONTRIBUTION_DUE
  GOAL_MILESTONE
  NEW_INVITE
}

enum GroupCategory {
  RENT
  ELECTRICITY
  WATER
  INTERNET
  TRIP
  GIFT
  OTHER
}

enum GroupStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

enum GroupType {
  BILL
  GOAL
}

enum MemberStatus {
  INVITED
  COMMITTED
  PAID
  DECLINED
}
